rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isHouseholdMember(householdId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/households/$(householdId)) && 
             (request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members);
    }

    function isValidAsset(data) {
      let typeOk = data.assetType == 'CASH' || data.assetType == 'TAXABLE' || data.assetType == 'PRE_TAX' || data.assetType == 'ROTH';
      let growthOk = isNumeric(data.expectedGrowthRate) && data.expectedGrowthRate >= -1.0 && data.expectedGrowthRate <= 1.0;
      let dividendOk = isNumeric(data.expectedDividendYield) && data.expectedDividendYield >= -1.0 && data.expectedDividendYield <= 1.0;
      let valueOk = isNumeric(data.value) && data.value >= 0;
      
      return typeOk && growthOk && dividendOk && valueOk;
    }
    
    function isValidTaxLot(data) {
      return data.id is string &&
             data.accountId is string &&
             data.ticker is string &&
             isNumeric(data.shares) && data.shares >= 0 &&
             isNumeric(data.costBasisPerShare) && data.costBasisPerShare >= 0 &&
             data.acquisitionDate is string &&
             data.isTargetConcentratedPosition is bool;
    }
    
    function isValidBridgeOptimization(data) {
      return data.id is string &&
             data.scenarioId is string &&
             isNumeric(data.optimalRothConversion) && data.optimalRothConversion >= 0 &&
             isNumeric(data.optimalLiquidation) && data.optimalLiquidation >= 0;
    }

    function isValidActualExpense(data) {
      return true;
    }

    function isValidPlanData(data) {
      let primaryBirthYearOk = !('primaryBirthYear' in data) || 
                               (data.primaryBirthYear is int && data.primaryBirthYear >= 1900 && data.primaryBirthYear <= 2100) || 
                               (data.primaryBirthYear is string && data.primaryBirthYear.size() <= 256);
      
      let rmdReinvestmentAssetIdOk = !('rmdReinvestmentAssetId' in data) || 
                                     (data.rmdReinvestmentAssetId is string && data.rmdReinvestmentAssetId.size() <= 128);
                                     
      let nameOk = !('name' in data) || (data.name is string && data.name.size() <= 120);
      
      let membersOk = !('members' in data) || (data.members is list && data.members.size() <= 10);
      
      let scenariosOk = !('scenarios' in data) || (data.scenarios is list && data.scenarios.size() <= 20);

      return primaryBirthYearOk && rmdReinvestmentAssetIdOk && nameOk && membersOk && scenariosOk;
    }

    // Allow any collection ending with -rxdb-replication-state at the root
    match /{collectionName}/{docId} {
      allow read, write: if isSignedIn() && collectionName.matches('.*-rxdb-replication-state');
    }

    // Allow nested collections under users
    match /users/{userId}/{collectionName}/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      
      allow create, update: if isSignedIn() && request.auth.uid == userId && 
        (
          (collectionName == 'assets' && isValidAsset(request.resource.data)) ||
          (collectionName == 'tax_lots' && isValidTaxLot(request.resource.data)) ||
          (collectionName == 'bridge_optimizations' && isValidBridgeOptimization(request.resource.data)) ||
          (collectionName == 'plans' && isValidPlanData(request.resource.data)) ||
          (collectionName != 'assets' && collectionName != 'tax_lots' && collectionName != 'bridge_optimizations' && collectionName != 'plans')
        );
    }

    match /households/{householdId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.members);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.members) && isValidPlanData(request.resource.data);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.members) && (request.auth.uid in request.resource.data.members) && isValidPlanData(request.resource.data);
      allow delete: if isSignedIn() && (request.auth.uid in resource.data.members);
    }

    match /actual_expenses/{actualId} {
      allow read: if isSignedIn() && isHouseholdMember(resource.data.householdId);
      
      allow create: if isSignedIn() &&
                    isValidId(actualId) &&
                    isValidActualExpense(incoming()) &&
                    incoming().id == actualId &&
                    isHouseholdMember(incoming().householdId);
                    
      allow update: if isSignedIn() &&
                    isValidId(actualId) &&
                    isValidActualExpense(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().userId == existing().userId &&
                    isHouseholdMember(existing().householdId) &&
                    incoming().householdId == existing().householdId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['category', 'amount', 'dateLogged', 'notes', 'updatedAt', 'serverTimestamp', '_deleted', '_rev', '_meta']);
                    
      allow delete: if isSignedIn() && isValidId(actualId) && isHouseholdMember(existing().householdId);
    }
  }
}
