rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Default-Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidScenario(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'isLocked', 'targetBudgetAmount', 'strategicRothConversionAmount']) &&
             data.keys().size() <= 9 &&
             data.id is string && data.id.size() <= 128 &&
             data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.isLocked is bool &&
             (data.targetBudgetAmount is int || data.targetBudgetAmount is float) &&
             (data.strategicRothConversionAmount is int || data.strategicRothConversionAmount is float) &&
             (!('fundingSources' in data) || (data.fundingSources is list && data.fundingSources.size() < 50)) &&
             (!('createdAt' in data) || data.createdAt is int) &&
             (!('updatedAt' in data) || data.updatedAt is int);
    }

    // Sub-collections under /users/{userId}
    match /users/{userId}/historical_datapoints/{id} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/links/{id} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/budgets/{id} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/planned_expenses/{id} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/assets/{id} {
      allow read, write: if isOwner(userId);
    }

    match /users/{userId}/categories/{id} {
      allow read, write: if isOwner(userId);
    }

    // Secure Scenario path with precise validations
    match /users/{userId}/tax_planning_scenarios/{scenarioId} {
      allow read, delete: if isOwner(userId);
      allow create: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid &&
                       isValidScenario(request.resource.data);
      allow update: if isOwner(userId) && 
                       request.resource.data.userId == request.auth.uid &&
                       isValidScenario(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId &&
                       request.resource.data.id == resource.data.id;
    }

    // Households collection
    match /households/{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}

