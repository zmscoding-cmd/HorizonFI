rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    function isCheckpoint(id) {
      return id is string && id.matches('^checkpoint-.*');
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isHouseholdMember(householdId) {
      return isSignedIn() &&
             exists(/databases/$(database)/documents/households/$(householdId)) &&
             (request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.members);
    }

    function isValidHistoricalDatapoint(data) {
      return data.keys().hasAll(['id', 'userId', 'date', 'aggregatedNetWorth']) &&
             data.id is string && data.id.size() > 0 &&
             data.userId is string && data.userId == request.auth.uid &&
             data.date is string &&
             isNumeric(data.aggregatedNetWorth);
    }

    function isValidScenarioItem(scenario) {
      return scenario.keys().hasAll(['id', 'name', 'budget']) &&
             scenario.id is string &&
             scenario.name is string &&
             scenario.budget is map;
    }

    function isScenarioValid(sc) {
      return sc is map && isValidScenarioItem(sc);
    }

    function isValidAsset(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'value']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string &&
             isNumeric(data.value);
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['id', 'userId', 'name']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string;
    }

    function isValidThreeBuckets(tb) {
      return tb is map &&
             tb.keys().hasAll(['bucket1LiquiditySecuredYears', 'bucket2IncomeSecuredYears', 'bucket3GrowthRemainingYears', 'rebalancingTriggerType']) &&
             isNumeric(tb.bucket1LiquiditySecuredYears) &&
             isNumeric(tb.bucket2IncomeSecuredYears) &&
             isNumeric(tb.bucket3GrowthRemainingYears) &&
             tb.rebalancingTriggerType is string;
    }

    function isValidBudgetPhase(phase) {
      return phase is map &&
             phase.keys().hasAll(['phaseId', 'startYear', 'endYear', 'baselineAmount', 'applyLifestyleAdjustment', 'lifestyleAdjustmentRate']) &&
             phase.phaseId is string &&
             isNumeric(phase.startYear) &&
             isNumeric(phase.endYear) &&
             isNumeric(phase.baselineAmount) &&
             phase.applyLifestyleAdjustment is bool &&
             isNumeric(phase.lifestyleAdjustmentRate);
    }

    function areBudgetPhasesValid(phases) {
      return phases is list;
    }

    function isValidHousehold(data) {
      return (data.get('_deleted', false) == true) || 
             (data.get('id', '') is string && data.get('id', '').size() > 0 &&
              data.get('name', '') is string &&
              data.get('members', []) is list &&
              data.get('members', []).size() > 0);
    }

    function isValidPlan(data) {
      return (data.get('_deleted', false) == true) || 
             (data.get('id', '') is string && data.get('id', '').size() > 0 &&
              data.get('name', '') is string &&
              data.get('members', []) is list &&
              data.get('members', []).size() > 0);
    }

    function isValidPlannedExpense(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'frequency', 'valuationType']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string &&
             data.frequency is string &&
             data.valuationType is string;
    }

    function isValidBudget(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'totalPlaintextMonthly', 'totalPlaintextAnnual']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string &&
             isNumeric(data.totalPlaintextMonthly) &&
             isNumeric(data.totalPlaintextAnnual);
    }

    function isValidActualExpense(data) {
      return data.keys().hasAll(['id', 'userId', 'householdId', 'dateLogged']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.householdId is string &&
             data.dateLogged is string;
    }

    function isValidLink(data) {
      return data.keys().hasAll(['id', 'userId', 'name', 'url']) &&
             data.id is string &&
             data.userId is string && data.userId == request.auth.uid &&
             data.name is string &&
             data.url is string;
    }
    
    // Allow any collection ending with -rxdb-replication-state at the root, ONLY for the matching authenticated user UID
    match /{collectionName}/{docId} {
      allow read, write: if isSignedIn() && collectionName.matches('.*-rxdb-replication-state') && (docId.matches('.*' + request.auth.uid + '.*') || docId == request.auth.uid);
    }

    // Allow nested rxdb replication states under users
    match /users/{userId}/{collectionName}/{docId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId && collectionName.matches('.*-rxdb-replication-state');
    }
    
    match /users/{userId}/historical_datapoints/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidHistoricalDatapoint(incoming()));
    }
    match /users/{userId}/links/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidLink(incoming()));
    }
    match /users/{userId}/budgets/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidBudget(incoming()));
    }
    match /users/{userId}/planned_expenses/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidPlannedExpense(incoming()));
    }
    match /users/{userId}/assets/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidAsset(incoming()));
    }
    match /users/{userId}/categories/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidCategory(incoming()));
    }
    match /users/{userId}/plans/{docId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isSignedIn() && request.auth.uid == userId && (docId.matches('^checkpoint-.*') || isValidPlan(incoming()));
    }

    match /households/{householdId} {
      allow read, write: if isSignedIn() && householdId.matches('^checkpoint-.*') && (householdId.matches('.*' + request.auth.uid + '.*') || householdId == request.auth.uid);

      allow read: if isSignedIn() && (resource == null || (request.auth.uid in resource.data.get('members', [])));
      allow delete: if isSignedIn() && resource != null && (request.auth.uid in resource.data.get('members', []));
      
      allow create: if isSignedIn() && 
                    (request.auth.uid in incoming().get('members', [])) &&
                    (incoming().get('_deleted', false) == true || isValidHousehold(incoming()));
                    
      allow update: if isSignedIn() && 
                    resource != null && (request.auth.uid in resource.data.get('members', [])) &&
                    (incoming().get('_deleted', false) == true || isValidHousehold(incoming())) &&
                    (request.auth.uid in incoming().get('members', []));
    }

    match /actual_expenses/{actualId} {
      allow read: if isSignedIn() && isHouseholdMember(resource.data.householdId);
      
      allow create: if isSignedIn() &&
                    isValidId(actualId) &&
                    isValidActualExpense(incoming()) &&
                    incoming().id == actualId &&
                    isHouseholdMember(incoming().householdId);
                    
      allow update: if isSignedIn() &&
                    isValidId(actualId) &&
                    isValidActualExpense(incoming()) &&
                    incoming().id == existing().id &&
                    incoming().userId == existing().userId &&
                    isHouseholdMember(existing().householdId) &&
                    incoming().householdId == existing().householdId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['category', 'amount', 'dateLogged', 'notes', 'updatedAt', 'serverTimestamp', '_deleted', '_rev', '_meta']);
                    
      allow delete: if isSignedIn() && isValidId(actualId) && isHouseholdMember(existing().householdId);
    }
  }
}
